# ===========================================
# Hejmai - Variáveis de Ambiente
# ===========================================
# Copie este arquivo para .env e preencha os valores

# -------------------------------------------
# Telegram Bot
# -------------------------------------------
# Obtenha o token em https://t.me/BotFather
TELEGRAM_TOKEN=

# -------------------------------------------
# API FastAPI
# -------------------------------------------
# URL do banco de dados SQLite
DATABASE_URL=sqlite:////app/data/estoque.db

# Caminho para o banco de dados (usado dentro do container)
DATABASE_PATH=/app/data/estoque.db

# URL do Ollama (LLM local)
# Em produção, aponte para o servidor Ollama
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Modelo do Ollama para usar
MODEL=llama3

# -------------------------------------------
# Streamlit Interface
# -------------------------------------------
# URL da API para o Streamlit conectar
API_URL=http://api:8081

# Porta do Streamlit
STREAMLIT_SERVER_PORT=8501

# -------------------------------------------
# Desenvolvimento (opcional)
# -------------------------------------------
# Defina como "true" para habilitar debug
DEBUG=false
