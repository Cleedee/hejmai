# ===========================================
# Hejmai - Variáveis de Ambiente
# ===========================================
# Copie este arquivo para .env e ajuste os valores conforme necessário

# -------------------------------------------
# API FastAPI
# -------------------------------------------
# URL da API FastAPI (use http://api:8081 em Docker)
API_URL=http://localhost:8081

# Timeouts (em segundos)
API_TIMEOUT=30
NLP_TIMEOUT=60
CACHE_TTL=300

# Retry
MAX_RETRY=3

# Orçamento padrão (R$)
ORCAMENTO_LIMITE=500.00

# -------------------------------------------
# Banco de Dados
# -------------------------------------------
DATABASE_URL=sqlite:////app/data/estoque.db
DATABASE_PATH=/app/data/estoque.db

# -------------------------------------------
# Ollama (IA)
# -------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
MODEL=llama3

# -------------------------------------------
# Telegram Bot
# -------------------------------------------
# Obtenha o token em https://t.me/BotFather
TELEGRAM_TOKEN=

# Seu Chat ID (use @userinfobot no Telegram)
TELEGRAM_CHAT_ID=123456789

# Usuários permitidos (separados por vírgula). Se vazio, usa apenas CHAT_ID_PESSOAL.
# Exemplo: TELEGRAM_ALLOWED_USERS=123456789,987654321
TELEGRAM_ALLOWED_USERS=

# Grupos permitidos (Chat IDs negativos, separados por vírgula)
# Exemplo: TELEGRAM_ALLOWED_GROUPS=-1001234567890,-1009876543210
TELEGRAM_ALLOWED_GROUPS=
