# ===========================================
# Hejmai Interface - Secrets do Streamlit
# ===========================================
# Copie este arquivo para secrets.toml e preencha com valores sensíveis
# NUNCA commitar este arquivo no git!

# ===========================================
# Configurações da API
# ===========================================
# URL da API (pode sobrescrever a variável de ambiente)
# API_URL = "http://localhost:8081"

# ===========================================
# Orçamentos
# ===========================================
# Limite de orçamento padrão (R$)
# ORCAMENTO_LIMITE = 500.00

# ===========================================
# Timeouts
# ===========================================
# Timeout para chamadas de API (segundos)
# API_TIMEOUT = 30
# NLP_TIMEOUT = 60
